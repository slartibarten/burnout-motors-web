# Kopier denne filen til .env.local og fyll inn verdiene fra Hostinger hPanel

# Database. På Hostinger må DB_HOST være 127.0.0.1 (IKKE localhost — localhost
# blir IPv6 ::1 og MySQL-brukeren er kun grantet fra IPv4).
DB_HOST=127.0.0.1
DB_USER=ditt_brukernavn
DB_PASSWORD=ditt_passord
DB_NAME=ditt_databasenavn
DB_SSL=false

# Resend API-nøkkel for e-postvarsler
RESEND_API_KEY=re_din_nokkel

# Token for å omgå maintenance mode: /?preview=<token>. Bruk en lang, tilfeldig
# verdi (f.eks. `openssl rand -hex 16`). Uten denne er bypass umulig.
PREVIEW_TOKEN=sett_en_tilfeldig_verdi
